# ──────────────────────────────────────────────
# NoSugar CSS Chat — environment variables
# Copy this file to .env.local and fill in values
# Never commit .env.local to version control
# ──────────────────────────────────────────────

# ── Frontend (exposed to browser via import.meta.env) ──────────────────────────

# Your production site URL (used in email links and CORS header)
VITE_SITE_URL=https://nosugar.css

# ── Supabase ───────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your Supabase project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Ko-fi ─────────────────────────────────────────────────────────────────────
# Found in: Ko-fi → Settings → Webhooks → Verification Token

KOFI_VERIFICATION_TOKEN=your-kofi-verification-token

# ── Resend ────────────────────────────────────────────────────────────────────
# Found in: resend.com → API Keys

RESEND_API_KEY=re_...

# Verified sender — must match your verified domain in Resend
RESEND_FROM=NoSugar CSS Chat <noreply@nosugar.css>
